{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PlainView",
  "version": "0.7.2",
  "identifier": "com.plainview.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PlainView",
        "label": "main",
        "width": 800,
        "height": 600,
        "minWidth": 280,
        "minHeight": 240,
        "decorations": false,
        "shadow": true,
        "center": true,
        "resizable": true,
        "transparent": false,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost https://asset.localhost blob: data:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": [
          "jpg",
          "jpeg",
          "png",
          "webp",
          "gif",
          "bmp",
          "tif",
          "tiff",
          "ico",
          "avif",
          "heic",
          "heif",
          "jxl",
          "psd",
          "tga",
          "dds",
          "pbm",
          "pgm",
          "pnm",
          "ppm",
          "pam",
          "raw",
          "cr2",
          "nef",
          "arw"
        ],
        "mimeType": "image/*",
        "description": "Image File"
      }
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false,
        "languages": ["Korean", "English"]
      }
    }
  }
}
